---
import ReferenceLayout from "../../layouts/ReferenceLayout.astro";
import Copy from "../../components/Copy.astro";
import ScoreMatrix from "../../components/ScoreMatrix.astro";
import {
  clipsForEnvironment,
  environments,
  formatScore,
  models,
  showcase,
} from "../../lib/showcase";
import { withBase } from "../../lib/paths";

const toc = [
  { id: "record", en: "Experiment record", zh: "实验记录" },
  { id: "matrix", en: "Score matrix", zh: "分数矩阵" },
  { id: "lanes", en: "Agent lanes", zh: "Agent 链路" },
  { id: "reruns", en: "Policy reruns", zh: "Policy 重跑" },
  { id: "methodology", en: "Methodology", zh: "方法" },
  { id: "interpretation", en: "Interpretation", zh: "结果解读" },
];

const agentRows = showcase.leaderboard.filter((row) => row.model_slug !== "random_policy");
const wins = Object.fromEntries(models.map((model) => [model.slug, 0]));
for (const env of environments) {
  const top = Math.max(...agentRows.map((row) => row.scores[env.id]));
  for (const row of agentRows) {
    if (row.scores[env.id] === top) wins[row.model_slug] += 1;
  }
}

const featuredIds = showcase.strategy_envs;
const featuredClips = featuredIds.map((envId) => {
  const clips = clipsForEnvironment(envId);
  return [...clips].sort((a, b) => b.score - a.score)[0];
});
---

<ReferenceLayout
  title="Core16 experiment results — EvoPolicyGym Documentation"
  description="The Core16 paper-companion score matrix, methodology, and final policy reruns."
  current="historical"
  {toc}
>
  <div class="results-reference">
    <header>
      <Copy class="reference-kicker" en="Paper companion · historical record" zh="论文伴随材料 · 历史记录" as="p" />
      <Copy en="Core16 experiment results" zh="Core16 实验结果" as="h1" />
      <Copy
        class="reference-lead"
        en="Validation-selected held-out returns and final-Policy reruns from four coding-agent/model lanes across sixteen interactive tasks."
        zh="四条 CodingAgent/模型链路在十六个交互任务中的 validation-selected held-out return 与最终 Policy 重跑记录。"
        as="p"
      />
    </header>

    <section id="record">
      <Copy en="Experiment record" zh="实验记录" as="h2" />
      <div class="reference-note is-warning">
        <strong><Copy en="Historical implementation" zh="历史实现" /></strong>
        <Copy
          en="These results were produced with the original EvoPolicyGym 0.1.0 research implementation. They were not generated by the current v0.3 Kernel and do not imply that Core16 adapters are currently distributed."
          zh="这些结果由最初的 EvoPolicyGym 0.1.0 研究实现产生，并非来自当前 v0.3 Kernel，也不表示 Core16 adapters 当前仍作为可安装环境提供。"
          as="p"
        />
      </div>
      <dl class="reference-definition">
        <dt><Copy en="Version" zh="版本" /></dt>
        <dd><code>v0.1.0</code></dd>
        <dt><Copy en="Suite" zh="任务套件" /></dt>
        <dd>{environments.length} <Copy en="interactive tasks" zh="个交互任务" /></dd>
        <dt><Copy en="Lanes" zh="实验链路" /></dt>
        <dd>{models.length} <Copy en="coding-agent/model combinations" zh="组 Coding Agent / 模型组合" /></dd>
        <dt><Copy en="Budget" zh="交互预算" /></dt>
        <dd>128 <Copy en="Environment episodes per run" zh="个 Environment episodes / Run" /></dd>
        <dt><Copy en="Reported value" zh="报告值" /></dt>
        <dd><Copy en="Mean held-out return of the validation-selected Policy" zh="由 validation 选出的 Policy 在 held-out Cases 上的 mean return" /></dd>
        <dt><Copy en="Behavior record" zh="行为记录" /></dt>
        <dd>{showcase.clips.length} <Copy en="final-Policy reruns" zh="段最终 Policy 重跑" /></dd>
        <dt><Copy en="Companion built" zh="伴随材料生成时间" /></dt>
        <dd><time datetime={showcase.generated_at}>{showcase.generated_at.slice(0, 10)}</time></dd>
      </dl>
      <p class="reference-actions">
        <a href="https://github.com/Linzwcs/EvoPolicyGym/tree/v0.1.0" target="_blank" rel="noreferrer">
          <Copy en="Tagged experiment source ↗" zh="已标记的实验源码 ↗" />
        </a>
        <a href="http://arxiv.org/abs/2607.02440" target="_blank" rel="noreferrer">
          <Copy en="Paper ↗" zh="论文 ↗" />
        </a>
        <a href={withBase("research/")}><Copy en="Research context →" zh="研究背景 →" /></a>
      </p>
    </section>

    <section id="matrix">
      <Copy en="Reported held-out return" zh="报告的 held-out return" as="h2" />
      <Copy
        en="Each column is a separate task with its own reward scale. Higher is better within a column; raw returns should not be averaged or compared directly across tasks."
        zh="每一列都是具有独立 reward scale 的任务。分数只应在同一列内比较，不能跨任务直接比较或对 raw return 求平均。"
        as="p"
      />
      <ScoreMatrix />
      <Copy
        class="reference-caption"
        en="Highlighted cells are column maxima across the four coding-agent/model lanes and the random-policy baseline. The first column remains fixed while scrolling."
        zh="高亮单元格表示四条 Coding Agent / 模型链路与 random-policy baseline 中的列内最大值；横向滚动时首列保持固定。"
        as="p"
      />
    </section>

    <section id="lanes">
      <Copy en="Agent lanes" zh="Agent 链路" as="h2" />
      <Copy
        en="All four lanes were measured on the same Core16 surface. Column-best counts are included only as a compact description of the matrix."
        zh="四条链路使用相同的 Core16 测量表面。列内最佳次数仅用于概括矩阵，不构成聚合 Benchmark 分数。"
        as="p"
      />
      <table class="reference-table">
        <thead>
          <tr>
            <th><Copy en="Model" zh="模型" /></th>
            <th><Copy en="Agent harness" zh="Agent harness" /></th>
            <th><Copy en="Column bests" zh="列内最佳" /></th>
          </tr>
        </thead>
        <tbody>
          {models.map((model) => (
            <tr>
              <td><strong>{model.display}</strong></td>
              <td><code>{model.harness}</code></td>
              <td>{wins[model.slug]} / {environments.length}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section id="reruns">
      <Copy en="Final-Policy reruns" zh="最终 Policy 重跑" as="h2" />
      <Copy
        en="The archive contains one original-environment rerun for every model–environment lane. These four examples foreground environments where policy structure is visually legible."
        zh="档案为每个模型–环境链路保留一次原环境重跑。下面四个例子选择了 Policy 行为结构较容易直观检查的环境。"
        as="p"
      />
      <div class="reference-rollouts">
        {featuredClips.map((clip) => (
          <a href={withBase(`results/environments/${clip.env_id}/`)}>
            <figure>
              <img
                src={withBase(clip.media)}
                alt={`${clip.model_display} final Policy rerun in ${clip.env_display}`}
                loading="lazy"
              />
              <figcaption>
                <strong>{clip.env_display}</strong>
                <span>{clip.model_display} · {formatScore(clip.score)}</span>
              </figcaption>
            </figure>
          </a>
        ))}
      </div>
      <p class="reference-actions">
        <a href={withBase("results/core16/")}><Copy en="Browse all 64 reruns →" zh="浏览全部 64 段重跑 →" /></a>
      </p>
    </section>

    <section id="methodology">
      <Copy en="Selection and measurement" zh="选择与测量" as="h2" />
      <table class="reference-table">
        <thead>
          <tr>
            <th><Copy en="Stage" zh="阶段" /></th>
            <th><Copy en="Role" zh="作用" /></th>
            <th><Copy en="Visibility" zh="可见性" /></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>TRAIN</code></td>
            <td><Copy en="The agent edits its Policy and spends Environment episodes to test submissions." zh="Agent 编辑 Policy，并消耗 Environment episodes 测试 submissions。" /></td>
            <td><Copy en="Visible, budgeted feedback" zh="可见、有预算约束的反馈" /></td>
          </tr>
          <tr>
            <td><code>VALIDATION</code></td>
            <td><Copy en="Selects which submitted checkpoint proceeds to final measurement." zh="选择进入最终测量的已提交 checkpoint。" /></td>
            <td><Copy en="Hidden from the agent" zh="对 Agent 隐藏" /></td>
          </tr>
          <tr>
            <td><code>HELD-OUT</code></td>
            <td><Copy en="Produces the mean return reported in the score matrix." zh="产生分数矩阵中报告的 mean return。" /></td>
            <td><Copy en="Hidden; never optimization feedback" zh="隐藏；不作为优化反馈" /></td>
          </tr>
          <tr>
            <td><code>RERUN</code></td>
            <td><Copy en="Replays the selected Policy in the original environment for behavioral inspection." zh="在原环境中重放所选 Policy，用于检查其行为。" /></td>
            <td><Copy en="Published qualitative evidence" zh="公开的定性证据" /></td>
          </tr>
        </tbody>
      </table>
    </section>

    <section id="interpretation">
      <Copy en="How to read these results" zh="如何解读这些结果" as="h2" />
      <ul>
        <li><Copy en="Compare scores only within the same Environment column." zh="只在同一个 Environment 列内比较分数。" /></li>
        <li><Copy en="Do not average raw returns across tasks with different reward scales." zh="不要对不同 reward scale 的任务直接计算 raw return 平均值。" /></li>
        <li><Copy en="Treat column-best counts as descriptive summaries, not a leaderboard score." zh="列内最佳次数只是描述性摘要，不是 leaderboard 总分。" /></li>
        <li><Copy en="Use reruns to inspect behavior; they are not additional held-out measurements." zh="重跑用于检查行为，不是额外的 held-out 测量。" /></li>
        <li><Copy en="Treat the entire page as historical v0.1.0 evidence, separate from current v0.3 package availability." zh="整页内容属于历史 v0.1.0 证据，应与当前 v0.3 package 可用性分开理解。" /></li>
      </ul>
      <div class="reference-next">
        <a href={withBase("results/core16/")}>
          <strong><Copy en="Rerun archive" zh="重跑档案" /></strong>
          <small><Copy en="All 64 model–environment records." zh="全部 64 条模型–环境记录。" /></small>
        </a>
        <a href={withBase("research/")}>
          <strong><Copy en="Research" zh="研究" /></strong>
          <small><Copy en="Claims, evidence, and current questions." zh="研究主张、证据与当前问题。" /></small>
        </a>
        <a href={withBase("research/protocol-design/")}>
          <strong><Copy en="Protocol design" zh="协议设计" /></strong>
          <small><Copy en="Budgets, lifecycle, and evidence boundaries." zh="预算、生命周期与证据边界。" /></small>
        </a>
      </div>
    </section>
  </div>
</ReferenceLayout>
